#!/bin/bash
# Pre-commit hook: run all unit tests before allowing commit
# Exit code 0 = allow commit, non-zero = block commit

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit tests...${NC}"

FAILED=0

# admin-web (Node.js/Vitest)
if [ -d "admin-web" ] && [ -f "admin-web/package.json" ]; then
    echo -e "\n${YELLOW}[admin-web] Running vitest...${NC}"
    cd admin-web
    if pnpm test; then
        echo -e "${GREEN}[admin-web] Tests passed${NC}"
    else
        echo -e "${RED}[admin-web] Tests FAILED${NC}"
        FAILED=1
    fi
    cd ..
fi

# auth-service (Python/pytest)
if [ -d "auth-service" ] && [ -f "auth-service/pyproject.toml" ]; then
    echo -e "\n${YELLOW}[auth-service] Running pytest...${NC}"
    cd auth-service
    if uv run pytest -q; then
        echo -e "${GREEN}[auth-service] Tests passed${NC}"
    else
        echo -e "${RED}[auth-service] Tests FAILED${NC}"
        FAILED=1
    fi
    cd ..
fi

echo ""
if [ $FAILED -eq 1 ]; then
    echo -e "${RED}❌ Pre-commit tests failed. Fix the above failures before committing.${NC}"
    exit 1
else
    echo -e "${GREEN}✅ All tests passed. Proceeding with commit.${NC}"
    exit 0
fi