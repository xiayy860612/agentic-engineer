# Copy to .env and/or .env.local (both gitignored). Load order: .env -> .env.local
# (later wins). Process env vars BIZ_* always override files. Put secrets in .env.local.

# Async SQLAlchemy connection to Supabase Postgres (or local Postgres)
# Example (Supabase pooler): postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
BIZ_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# Supabase JWKS endpoint for access token verification
BIZ_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Comma-separated origins for CORS (no trailing slash)
BIZ_CORS_ORIGINS=http://localhost:3000
